# =============================================================================
# Shared secrets (used by BOTH development and production Docker Compose)
# Copy to `.env` in the repo root: cp .env.example .env
# =============================================================================
JWT_SECRET=your_jwt_secret_here
ADMIN_EMAIL=admin@floratechnologies.in
ADMIN_PASSWORD=SecurePass123!

# -----------------------------------------------------------------------------
# PRODUCTION ONLY — optional overrides for docker-compose.prod.yml
# Leave commented when using `docker compose up` (development).
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=https://www.floratechnologies.in
# NEXT_PUBLIC_API_URL=https://api.floratechnologies.in
# CORS_ORIGINS=https://www.floratechnologies.in,https://floratechnologies.in,https://admin.floratechnologies.in
# VITE_API_URL=https://api.floratechnologies.in/api
#
# Lead form → email (backend). SMTP_USER = Gmail account that owns the app password.
# LEAD_NOTIFY_EMAIL = comma-separated list (each address receives new leads).
# LEAD_NOTIFY_EMAIL=you1@gmail.com,you2@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you1@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM=Flora Website <you1@gmail.com>
