# =============================================================================
# BACKEND — copy to backend/.env for `npm run dev` (without Docker)
# Docker Compose injects its own env; this file is the local-CLI reference.
# =============================================================================

PORT=4000

# development | production
NODE_ENV=development

MONGODB_URI=mongodb://localhost:27017/flora_tech
JWT_SECRET=your_jwt_secret_here
ADMIN_EMAIL=admin@floratechnologies.in
ADMIN_PASSWORD=SecurePass123!

# --- Development: browser origins (Next + Vite admin on localhost) ----------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5050,http://127.0.0.1:5050,http://localhost:5174,http://127.0.0.1:5174,http://localhost:4174,http://127.0.0.1:4174

# --- Production: replace when deploying behind nginx (see docker-compose.prod.yml)
# NODE_ENV=production
# TRUST_PROXY=1
# CORS_ORIGINS=https://www.floratechnologies.in,https://floratechnologies.in,https://admin.floratechnologies.in

# Optional: trust first proxy hop (nginx). Required in production behind reverse proxy.
# TRUST_PROXY=1

# Optional: override default /api rate limit (per IP per 15m)
# RATE_LIMIT_MAX=300

# --- Optional: email when a contact form lead is saved (nodemailer / SMTP) ---
# LEAD_NOTIFY_EMAIL=addr1@gmail.com,addr2@gmail.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=addr1@gmail.com
# SMTP_PASS=your_gmail_app_password
# SMTP_FROM=Flora Website <addr1@gmail.com>
