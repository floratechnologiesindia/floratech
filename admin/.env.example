# =============================================================================
# ADMIN (Vite) — copy to admin/.env for `npm run dev`
# Production API URL is baked in at `npm run build` (see docker-compose.prod.yml args).
# Open the built app at https://admin.floratechnologies.in (nginx → host :4174; see nginx.conf.example).
# =============================================================================

# --- Development: local API ---------------------------------------------------
VITE_API_URL=http://127.0.0.1:4000/api

# --- Production: used when building the admin image ----------------------------
# VITE_API_URL=https://api.floratechnologies.in/api
