# =============================================================================
# Shared secrets (used by BOTH development and production Docker Compose)
# Copy to `.env` in the repo root: cp .env.example .env
# =============================================================================
JWT_SECRET=your_jwt_secret_here
ADMIN_EMAIL=admin@floratechnologies.in
ADMIN_PASSWORD=SecurePass123!

