# PRODUCTION reverse proxy — use with `docker-compose.prod.yml` (NOT docker-compose.yml).
# Upstreams = host ports published by production containers:
#   Frontend (Next.js):  http://127.0.0.1:5050  -> container :3000
#   Backend (Express):   http://127.0.0.1:5000  -> container :4000
#   Admin (Vite preview): http://127.0.0.1:4174 -> container :4174
#
# Public URLs:
#   Site:  https://www.floratechnologies.in (and floratechnologies.in)
#   API:   https://api.floratechnologies.in
#   Admin: https://admin.floratechnologies.in
#
# DNS: add an A/AAAA record for admin → your server IP.
# TLS: include admin.floratechnologies.in in your certificate (e.g. certbot -d ... -d admin.floratechnologies.in).
#
# Match app env: NEXT_PUBLIC_SITE_URL, NEXT_PUBLIC_API_URL, CORS_ORIGINS (must include admin origin), VITE_API_URL (see .env.example).

# Frontend: www.floratechnologies.in
server {
    server_name floratechnologies.in www.floratechnologies.in;

    location / {
        proxy_pass         http://127.0.0.1:5050;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/floratechnologies.in/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/floratechnologies.in/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot


}

# Backend API: api.floratechnologies.in
server {
    server_name api.floratechnologies.in;

    location / {
        proxy_pass         http://127.0.0.1:5000;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/floratechnologies.in/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/floratechnologies.in/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

# Admin panel: admin.floratechnologies.in
server {
    server_name admin.floratechnologies.in;

    location / {
        proxy_pass         http://127.0.0.1:4174;
        proxy_http_version 1.1;

        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/floratechnologies.in/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/floratechnologies.in/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}


server {
    if ($host = www.floratechnologies.in) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    if ($host = floratechnologies.in) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name floratechnologies.in www.floratechnologies.in;
    return 404; # managed by Certbot




}
server {
    if ($host = api.floratechnologies.in) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name api.floratechnologies.in;
    return 404; # managed by Certbot


}

server {
    if ($host = admin.floratechnologies.in) {
        return 301 https://$host$request_uri;
    } # managed by Certbot

    listen 80;
    server_name admin.floratechnologies.in;
    return 404; # managed by Certbot
}