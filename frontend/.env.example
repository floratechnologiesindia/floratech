# =============================================================================
# FRONTEND — copy to frontend/.env.local (local npm) or rely on Docker env
# =============================================================================

# --- Development (npm run dev, or docker-compose.yml) -----------------------
# Server-side API base (same machine: 127.0.0.1; inside dev Docker: use http://backend:4000 via compose)
API_URL=http://127.0.0.1:4000

# Browser: contact form & client fetches — must be reachable from the browser
NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# Canonical URL for SEO (sitemap, robots, OG). Use localhost in dev.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Production (docker-compose.prod.yml sets these; or set in .env.local) --
# API_URL=http://backend:4000
# NEXT_PUBLIC_API_URL=https://api.floratechnologies.in
# NEXT_PUBLIC_SITE_URL=https://www.floratechnologies.in
